{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=./data/db/objex.db"
  },
  "Storage": {
    "BasePath": "./data/blobs"
  },
  "S3": {
    "PublicUrl": "http://localhost:9000"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "./data/logs/objex-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "DefaultAdmin": {
    "Username": "admin",
    "Email": "admin@objex.local",
    "Password": "admin"
  }
}