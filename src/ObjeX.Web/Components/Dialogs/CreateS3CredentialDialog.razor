@inject DialogService DialogService

<RadzenStack Gap="1rem" Style="padding:1rem; min-width:320px">
    <div>
        <label style="display:block; margin-bottom:0.25rem; font-size:0.875rem">Name</label>
        <input class="rz-textbox" style="width:100%" value="@_name"
               @oninput="OnInput" @onkeydown="OnKeyDown" placeholder="e.g. my-app, rclone, mc" />
        <span style="font-size:0.75rem; visibility:@(_error is not null ? "visible" : "hidden"); color:var(--rz-danger)">
            @(_error ?? "placeholder")
        </span>
    </div>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(null))" />
        <RadzenButton Text="Create" ButtonStyle="ButtonStyle.Primary"
                      Disabled="@(_error is not null || string.IsNullOrWhiteSpace(_name))"
                      Click="OnCreate" />
    </RadzenStack>
</RadzenStack>

@code {
    string _name = string.Empty;
    string? _error;

    public record Result(string Name);

    void OnInput(ChangeEventArgs e)
    {
        _name = e.Value?.ToString() ?? string.Empty;
        _error = string.IsNullOrWhiteSpace(_name) ? "Name is required." : null;
    }

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _error is null && !string.IsNullOrWhiteSpace(_name)) OnCreate();
        else if (e.Key == "Escape") DialogService.Close(null);
    }

    void OnCreate() => DialogService.Close(new Result(_name.Trim()));
}
