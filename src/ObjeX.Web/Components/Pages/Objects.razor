@page "/buckets/{BucketName}"
@using ObjeX.Core.Interfaces
@using ObjeX.Core.Models
@using ObjeX.Web.Components.Dialogs
@using ObjeX.Infrastructure.Data
@using ObjeX.Core.Utilities
@using Microsoft.EntityFrameworkCore
@inject IMetadataService MetadataService
@inject IObjectStorageService StorageService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject AuthenticationStateProvider AuthStateProvider
@inject ObjeXDbContext Db
@inject IJSRuntime JS

<PageTitle>@BucketName — ObjeX</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <a href="/buckets" style="color:var(--rz-primary);text-decoration:none">Buckets</a>
            <RadzenText>/</RadzenText>
            <span style="color:var(--rz-primary);cursor:pointer" @onclick="@(() => NavigateToPrefix(string.Empty))">@BucketName</span>
            @foreach (var (segment, prefixUpTo) in GetBreadcrumbSegments())
            {
                <RadzenText>/</RadzenText>
                var upTo = prefixUpTo;
                <span style="color:var(--rz-primary);cursor:pointer" @onclick="@(() => NavigateToPrefix(upTo))">@segment</span>
            }
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="New Folder" Icon="create_new_folder"
                          ButtonStyle="ButtonStyle.Light" Disabled="@(!_bucketExists)"
                          Click="@OnNewFolderClick" />
            <RadzenButton Text="@(_uploading ? "Uploading..." : "Upload")" Icon="upload"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@(_uploading || !_bucketExists)"
                          Click="@OnUploadClick" />
        </RadzenStack>
    </RadzenStack>

    <RadzenCard Style="@($"padding:0.6rem 1rem;visibility:{(_selected.Count > 0 ? "visible" : "hidden")}")">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenText Style="color:var(--rz-text-secondary-color)">@_selected.Count selected</RadzenText>
            <RadzenButton Text="Download ZIP" Icon="download" ButtonStyle="ButtonStyle.Primary"
                          Size="ButtonSize.Small" Click="BulkDownload" />
            <RadzenButton Text="Delete" Icon="delete" ButtonStyle="ButtonStyle.Danger"
                          Size="ButtonSize.Small" Click="BulkDelete" />
            <RadzenButton Text="Clear" Icon="close" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" Click="@(() => _selected.Clear())" />
        </RadzenStack>
    </RadzenCard>

    <div class="objects-grid" style="overflow-x:auto">
    <RadzenDataGrid Data="@_rows" TItem="ListRow" AllowSorting="true" EmptyText="No objects in this bucket.">
        <Columns>
            <RadzenDataGridColumn TItem="ListRow" Width="48px" Sortable="false" Resizable="false">
                <HeaderTemplate>
                    <RadzenCheckBox TValue="bool"
                                    Value="@(_rows.Count > 0 && _selected.Count == _rows.Count)"
                                    Change="@(v => { if (v) _rows.ForEach(r => _selected.Add(r)); else _selected.Clear(); StateHasChanged(); })" />
                </HeaderTemplate>
                <Template Context="row">
                    <RadzenCheckBox TValue="bool" Value="@_selected.Contains(row)"
                                    Change="@(v => { if (v) _selected.Add(row); else _selected.Remove(row); StateHasChanged(); })" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ListRow" Title="Name">
                <Template Context="row">
                    @if (row.IsFolder)
                    {
                        <span style="color:var(--rz-primary);cursor:pointer" @onclick="@(() => NavigateToPrefix(row.FolderPath!))">@row.Name</span>
                    }
                    else
                    {
                        @row.Name
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ListRow" Title="Content Type">
                <Template Context="row">@(row.IsFolder ? "" : row.Object!.ContentType)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ListRow" Title="Size">
                <Template Context="row">@(row.IsFolder ? "" : FileHelper.FormatBytes(row.Object!.Size))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ListRow" Title="Uploaded">
                <Template Context="row">@(row.IsFolder ? "" : row.Object!.CreatedAt.ToString("yyyy-MM-dd HH:mm"))</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ListRow" Title="" Width="200px" Sortable="false">
                <Template Context="row">
                    <div style="display:flex;align-items:center;justify-content:flex-end">
                    @if (row.IsFolder)
                    {
                        <a href="/api/objects/@BucketName/download?prefix=@row.FolderPath" download="@(row.Name[..^1]).zip" target="_blank" style="display:flex">
                            <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" />
                        </a>
                        <RadzenButton Icon="link"       ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Text" style="visibility:hidden" />
                        <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light"     Variant="Variant.Text" style="visibility:hidden" />
                        <RadzenButton Icon="delete"     ButtonStyle="ButtonStyle.Danger"    Variant="Variant.Text"
                                      Click="@(() => OnDeleteFolder(row.FolderPath!))" />
                    }
                    else
                    {
                        <a href="@($"/api/objects/{BucketName}/{row.Object!.Key}?download=true")" download="@Path.GetFileName(row.Object!.Key)" target="_blank" style="display:flex">
                            <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" />
                        </a>
                        <RadzenButton Icon="link" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Text"
                                      Click="@(() => CopyPresignedLink(row.Object!))"
                                      title="Copy presigned link" />
                        @if (IsPreviewable(row.Object!.ContentType))
                        {
                            <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                          Click="@(() => PreviewObject(row.Object!))"
                                          title="Preview" />
                        }
                        else
                        {
                            <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" style="visibility:hidden" />
                        }
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                      Click="@(() => OnDeleteObject(row.Object!))" />
                    }
                    </div>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    </div>
</RadzenStack>

<style>
    .objects-grid .rz-data-grid-data td {
        height: 44px !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }
</style>

@code {
    [Parameter] public string BucketName { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "prefix")] public string? PrefixParam { get; set; }

    record ListRow(string Name, bool IsFolder, string? FolderPath = null, BlobObject? Object = null);

    List<ListRow> _rows = [];
    List<BlobObject> _objects = [];
    List<string> _folders = [];
    HashSet<ListRow> _selected = [];
    string _currentPrefix = string.Empty;
    bool _uploading;
    bool _bucketExists = true;

    protected override async Task OnInitializedAsync()
    {
        _currentPrefix = PrefixParam ?? string.Empty;
        _bucketExists = await MetadataService.ExistsBucketAsync(BucketName);
        if (_bucketExists)
            await LoadObjects();
        else
            NotificationService.Notify(NotificationSeverity.Error, "Bucket not found", $"\"{BucketName}\" does not exist.");
    }

    async Task LoadObjects()
    {
        var result = await MetadataService.ListObjectsAsync(
            BucketName,
            prefix: string.IsNullOrEmpty(_currentPrefix) ? null : _currentPrefix,
            delimiter: "/");
        _objects = result.Objects.ToList();
        _folders = result.CommonPrefixes.ToList();
        _rows = [
            .._folders.Select(f => new ListRow(f[_currentPrefix.Length..].TrimEnd('/') + "/", true, f)),
            .._objects.Where(o => !o.Key.EndsWith("/")).Select(o => new ListRow(o.Key[_currentPrefix.Length..], false, Object: o))
        ];
    }

    async Task NavigateToPrefix(string prefix)
    {
        _selected.Clear();
        _currentPrefix = prefix;
        var url = string.IsNullOrEmpty(prefix)
            ? $"/buckets/{BucketName}"
            : $"/buckets/{BucketName}?prefix={Uri.EscapeDataString(prefix)}";
        Navigation.NavigateTo(url, replace: true);
        await LoadObjects();
    }

    IEnumerable<(string Segment, string PrefixUpTo)> GetBreadcrumbSegments()
    {
        if (string.IsNullOrEmpty(_currentPrefix)) yield break;
        var parts = _currentPrefix.TrimEnd('/').Split('/');
        for (var i = 0; i < parts.Length; i++)
            yield return (parts[i], string.Join("/", parts[..(i + 1)]) + "/");
    }

    async Task OnNewFolderClick()
    {
        var name = await DialogService.OpenAsync<Dialogs.CreateFolderDialog>("New Folder");
        if (name is not string folderName || string.IsNullOrWhiteSpace(folderName)) return;

        var key = _currentPrefix + folderName.Trim('/') + "/";
        try
        {
            await using var empty = new MemoryStream();
            await using var hashingStream = new Core.Utilities.HashingStream(empty);
            var storagePath = await StorageService.StoreAsync(BucketName, key, hashingStream);
            await MetadataService.SaveObjectAsync(new BlobObject
            {
                BucketName = BucketName,
                Key = key,
                Size = 0,
                ContentType = "application/x-directory",
                ETag = hashingStream.GetETag(),
                StoragePath = storagePath
            });
            await LoadObjects();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to create folder", ex.Message);
        }
    }

    async Task OnUploadClick()
    {
        if (!await MetadataService.ExistsBucketAsync(BucketName))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Bucket not found", $"\"{BucketName}\" no longer exists.");
            return;
        }

        var result = await DialogService.OpenAsync<UploadObjectDialog>("Upload");
        if (result is not List<UploadObjectDialog.UploadFile> selectedFiles || selectedFiles.Count == 0) return;

        _uploading = true;
        var errors = new List<string>();

        foreach (var file in selectedFiles)
        {
            var key = _currentPrefix + file.Name;
            string? storagePath = null;
            try
            {
                using var ms = new MemoryStream(file.Data);
                await using var hashingStream = new Core.Utilities.HashingStream(ms);
                storagePath = await StorageService.StoreAsync(BucketName, key, hashingStream);
                var etag = hashingStream.GetETag();

                await MetadataService.SaveObjectAsync(new BlobObject
                {
                    BucketName = BucketName,
                    Key = key,
                    Size = file.Size,
                    ContentType = file.ContentType,
                    ETag = etag,
                    StoragePath = storagePath
                });
            }
            catch (Exception ex)
            {
                if (storagePath is not null)
                    await StorageService.DeleteAsync(BucketName, key);
                errors.Add($"{file.Name}: {ex.Message}");
            }
        }

        await LoadObjects();
        _uploading = false;

        if (errors.Count == 0)
            NotificationService.Notify(NotificationSeverity.Success, "Upload complete", $"{selectedFiles.Count} file(s) uploaded");
        else
            foreach (var err in errors)
                NotificationService.Notify(NotificationSeverity.Error, "Upload failed", err);
    }

    async Task OnDeleteFolder(string folderPath)
    {
        var confirmed = await DialogService.Confirm(
            $"Delete \"{folderPath.TrimEnd('/')}\" and all its contents?",
            "Delete Folder",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel", CloseDialogOnOverlayClick = true });

        if (confirmed != true) return;

        try
        {
            var result = await MetadataService.ListObjectsAsync(BucketName, prefix: folderPath, delimiter: null);
            var all = result.Objects.ToList();
            foreach (var obj in all)
            {
                await StorageService.DeleteAsync(BucketName, obj.Key);
                await MetadataService.DeleteObjectAsync(BucketName, obj.Key);
            }
            await LoadObjects();
            NotificationService.Notify(NotificationSeverity.Success, "Folder deleted", folderPath.TrimEnd('/'));
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to delete folder", ex.Message);
        }
    }

    async Task OnDeleteObject(BlobObject obj)
    {
        var confirmed = await DialogService.Confirm(
            $"Delete \"{obj.Key}\"?",
            "Delete Object",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel", CloseDialogOnOverlayClick = true });

        if (confirmed != true) return;

        try
        {
            await MetadataService.DeleteObjectAsync(BucketName, obj.Key);
            await LoadObjects();
            NotificationService.Notify(NotificationSeverity.Success, "Object deleted", obj.Key);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Failed to delete object", ex.Message);
        }
    }

    async Task BulkDelete()
    {
        var count = _selected.Count;
        var confirmed = await DialogService.Confirm(
            $"Delete {count} selected item(s)? This cannot be undone.",
            "Delete Selected",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel", CloseDialogOnOverlayClick = true });

        if (confirmed != true) return;

        var errors = new List<string>();
        foreach (var row in _selected.ToList())
        {
            try
            {
                if (row.IsFolder)
                {
                    var result = await MetadataService.ListObjectsAsync(BucketName, prefix: row.FolderPath!, delimiter: null);
                    foreach (var obj in result.Objects)
                    {
                        await StorageService.DeleteAsync(BucketName, obj.Key);
                        await MetadataService.DeleteObjectAsync(BucketName, obj.Key);
                    }
                }
                else
                {
                    await MetadataService.DeleteObjectAsync(BucketName, row.Object!.Key);
                }
            }
            catch (Exception ex) { errors.Add(ex.Message); }
        }

        _selected.Clear();
        await LoadObjects();

        if (errors.Count == 0)
            NotificationService.Notify(NotificationSeverity.Success, "Deleted", $"{count} item(s) deleted.");
        else
            foreach (var err in errors)
                NotificationService.Notify(NotificationSeverity.Error, "Delete failed", err);
    }

    async Task BulkDownload()
    {
        var allKeys = new List<string>();

        foreach (var row in _selected)
        {
            if (row.IsFolder)
            {
                var result = await MetadataService.ListObjectsAsync(BucketName, prefix: row.FolderPath!, delimiter: null);
                allKeys.AddRange(result.Objects.Where(o => !o.Key.EndsWith("/")).Select(o => o.Key));
            }
            else
            {
                allKeys.Add(row.Object!.Key);
            }
        }

        if (allKeys.Count == 0) return;

        var query = string.Join("&", allKeys.Select(k => $"keys={Uri.EscapeDataString(k)}"));
        var url = $"/api/objects/{BucketName}/download?{query}";
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='{url}';a.download='selection.zip';document.body.appendChild(a);a.click();document.body.removeChild(a);");
        _selected.Clear();
    }

    static bool IsPreviewable(string contentType) =>
        contentType.StartsWith("image/") ||
        contentType.StartsWith("video/") ||
        contentType.StartsWith("audio/") ||
        contentType.StartsWith("text/")  ||
        contentType == "application/pdf";

    async Task PreviewObject(BlobObject obj)
    {
        var url = $"/api/objects/{BucketName}/{obj.Key}";
        await DialogService.OpenAsync<Dialogs.FilePreviewDialog>(
            Path.GetFileName(obj.Key),
            new Dictionary<string, object?>
            {
                { "FileName",    Path.GetFileName(obj.Key) },
                { "ContentType", obj.ContentType },
                { "Url",         url },
            },
            new DialogOptions { Width = "860px", CloseDialogOnOverlayClick = true, ShowClose = true });
    }

    async Task CopyPresignedLink(BlobObject obj)
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        var credential = await Db.S3Credentials.AsNoTracking()
            .FirstOrDefaultAsync(c => c.UserId == userId);

        if (credential is null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No S3 credential", "Create one in Settings first.");
            return;
        }

        var settings      = await Db.SystemSettings.FindAsync(1);
        var defaultExpiry = settings?.PresignedUrlDefaultExpirySeconds ?? 3600;
        var maxExpiry     = settings?.PresignedUrlMaxExpirySeconds ?? 604800;

        var result = await DialogService.OpenAsync<Dialogs.PresignedUrlDialog>(
            "Share Link",
            new Dictionary<string, object?>
            {
                { "DefaultSeconds", defaultExpiry },
                { "MaxSeconds",     maxExpiry },
            },
            new DialogOptions { Width = "440px", CloseDialogOnOverlayClick = true });

        if (result is not int expiresSeconds) return;

        var s3BaseUrl = Configuration["S3:PublicUrl"] ?? "http://localhost:9000";
        var url = PresignedUrlGenerator.Generate(
            s3BaseUrl, BucketName, obj.Key,
            credential.AccessKeyId, credential.SecretAccessKey,
            expiresSeconds);

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);

        var expiresAt = DateTime.Now.AddSeconds(expiresSeconds);
        NotificationService.Notify(NotificationSeverity.Success, "Link copied", $"Expires at {expiresAt:HH:mm:ss}");
    }
}
