@page "/"
@using ObjeX.Core.Interfaces
@using ObjeX.Core.Models
@implements IDisposable
@inject IMetadataService MetadataService

<PageTitle>Dashboard — ObjeX</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween">
        <RadzenText TextStyle="TextStyle.H4">Dashboard</RadzenText>
        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
            Updated @_lastUpdated.ToString("HH:mm:ss")
        </RadzenText>
    </RadzenStack>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Style="flex-wrap:wrap">
        <RadzenCard class="stat-card">
            <RadzenStack Gap="0.4rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Overline">Total Buckets</RadzenText>
                    <RadzenIcon Icon="folder" Style="color:var(--rz-primary);opacity:0.8;font-size:1.4rem" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.H3">@_buckets.Count</RadzenText>
            </RadzenStack>
        </RadzenCard>
        <RadzenCard class="stat-card">
            <RadzenStack Gap="0.4rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Overline">Total Objects</RadzenText>
                    <RadzenIcon Icon="description" Style="color:var(--rz-primary);opacity:0.8;font-size:1.4rem" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.H3">@_totalObjects.ToString("N0")</RadzenText>
            </RadzenStack>
        </RadzenCard>
        <RadzenCard class="stat-card">
            <RadzenStack Gap="0.4rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Overline">Storage Used</RadzenText>
                    <RadzenIcon Icon="save" Style="color:var(--rz-primary);opacity:0.8;font-size:1.4rem" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.H3">@FileHelper.FormatBytes(_totalSize)</RadzenText>
            </RadzenStack>
        </RadzenCard>
        <RadzenCard class="stat-card">
            <RadzenStack Gap="0.4rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.Overline">Avg Object Size</RadzenText>
                    <RadzenIcon Icon="compress" Style="color:var(--rz-primary);opacity:0.8;font-size:1.4rem" />
                </RadzenStack>
                <RadzenText TextStyle="TextStyle.H3">@(_totalObjects > 0 ? FileHelper.FormatBytes(_totalSize / _totalObjects) : "—")</RadzenText>
            </RadzenStack>
        </RadzenCard>
    </RadzenStack>

    @if (_buckets.Count >= 2)
    {
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Style="flex-wrap:wrap">
            <RadzenCard Style="flex:1;min-width:260px;overflow:visible">
                <RadzenStack Gap="0.75rem">
                    <RadzenStack Gap="0.1rem">
                        <RadzenText TextStyle="TextStyle.H6">Storage by Bucket</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Top 5 by size</RadzenText>
                    </RadzenStack>
                    <RadzenChart Style="height:240px;overflow:visible">
                        <RadzenDonutSeries Data="@_topBySize" CategoryProperty="Name" ValueProperty="TotalSize"
                                           TItem="Bucket" InnerRadius="60">
                            <TooltipTemplate Context="data">
                                <div>
                                    <div style="font-weight:600;margin-bottom:2px">@data.Name</div>
                                    <div>@FileHelper.FormatBytes(data.TotalSize)</div>
                                    @if (_totalSize > 0)
                                    {
                                        <div style="opacity:0.7;font-size:0.85em">@($"{(double)data.TotalSize / _totalSize * 100:F1}%")</div>
                                    }
                                </div>
                            </TooltipTemplate>
                        </RadzenDonutSeries>
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard Style="flex:1;min-width:260px;overflow:visible">
                <RadzenStack Gap="0.75rem">
                    <RadzenStack Gap="0.1rem">
                        <RadzenText TextStyle="TextStyle.H6">Objects by Bucket</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Top 5 by count</RadzenText>
                    </RadzenStack>
                    <RadzenChart Style="height:240px;overflow:visible">
                        <RadzenColumnSeries Data="@_topByCount" CategoryProperty="Name" ValueProperty="ObjectCount"
                                            TItem="Bucket" Title="Objects" />
                        <RadzenCategoryAxis />
                        <RadzenValueAxis />
                        <RadzenLegend Visible="false" />
                    </RadzenChart>
                </RadzenStack>
            </RadzenCard>
            @if (_fileTypeStats.Count >= 2)
            {
                <RadzenCard Style="flex:1;min-width:260px;overflow:visible">
                    <RadzenStack Gap="0.75rem">
                    <RadzenStack Gap="0.1rem">
                        <RadzenText TextStyle="TextStyle.H6">File Types</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">Top 8 by extension</RadzenText>
                    </RadzenStack>
                        <RadzenChart Style="height:240px;overflow:visible">
                            <RadzenDonutSeries Data="@_fileTypeStats" CategoryProperty="Label" ValueProperty="Count"
                                               TItem="FileTypeStat" InnerRadius="60">
                                <TooltipTemplate Context="data">
                                    <div>
                                        <div style="font-weight:600;margin-bottom:2px">@data.Label</div>
                                        <div>@data.Count files</div>
                                        @if (_totalFileTypeCount > 0)
                                        {
                                            <div style="opacity:0.7;font-size:0.85em">@($"{(double)data.Count / _totalFileTypeCount * 100:F1}%")</div>
                                        }
                                    </div>
                                </TooltipTemplate>
                            </RadzenDonutSeries>
                        </RadzenChart>
                    </RadzenStack>
                </RadzenCard>
            }
        </RadzenStack>
    }


    @if (_buckets.Count > 0)
    {
        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6">Buckets</RadzenText>
                <div style="overflow-x:auto">
                <RadzenDataGrid Data="@_buckets" TItem="Bucket" AllowSorting="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="Bucket" Property="Name" Title="Name">
                            <Template Context="b">
                                <a href="/buckets/@b.Name" style="color:var(--rz-primary);text-decoration:none">@b.Name</a>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Bucket" Property="ObjectCount" Title="Objects">
                            <Template Context="b">@b.ObjectCount.ToString("N0")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Bucket" Property="TotalSize" Title="Size">
                            <Template Context="b">@FileHelper.FormatBytes(b.TotalSize)</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Bucket" Title="Share" Sortable="false">
                            <Template Context="b">
                                @if (_totalSize > 0)
                                {
                                    var pct = (double)b.TotalSize / _totalSize * 100;
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <div style="flex:1;background:var(--rz-base-300);border-radius:4px;height:6px;overflow:hidden">
                                            <div style="width:@(pct.ToString("F1"))%;background:var(--rz-primary);height:100%"></div>
                                        </div>
                                        <span style="min-width:3rem;text-align:right;font-size:0.8rem">@pct.ToString("F1")%</span>
                                    </RadzenStack>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Bucket" Property="CreatedAt" Title="Created">
                            <Template Context="b">@b.CreatedAt.ToString("yyyy-MM-dd")</Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                </div>
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

<style>
    .rz-data-grid-data td { height: 44px !important; padding-top: 0 !important; padding-bottom: 0 !important; }

    .stat-card {
        flex: 1;
        min-width: 140px;
        border-left: 3px solid var(--rz-primary);
    }
    .stat-icon {
        font-size: 1.4rem;
        color: var(--rz-primary);
        opacity: 0.8;
    }

</style>

@code {
    record FileTypeStat(string Label, int Count);

    List<Bucket> _buckets = [];
    List<Bucket> _topBySize = [];
    List<Bucket> _topByCount = [];
    List<FileTypeStat> _fileTypeStats = [];
    long _totalObjects;
    long _totalSize;
    int _totalFileTypeCount;
    DateTime _lastUpdated = DateTime.Now;
    Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
        _timer = new Timer(async _ =>
        {
            await LoadStats();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    async Task LoadStats()
    {
        _buckets = (await MetadataService.ListBucketsAsync()).OrderByDescending(b => b.TotalSize).ToList();
        _totalObjects = _buckets.Sum(b => b.ObjectCount);
        _totalSize    = _buckets.Sum(b => b.TotalSize);
        _topBySize  = _buckets.Take(5).ToList();
        _topByCount = _buckets.OrderByDescending(b => b.ObjectCount).Take(5).ToList();

        var allObjects = (await MetadataService.ListAllObjectsAsync())
            .Where(o => !o.Key.EndsWith("/"))
            .ToList();

        _fileTypeStats = allObjects
            .GroupBy(o => {
                var ext = System.IO.Path.GetExtension(o.Key).ToLowerInvariant();
                return string.IsNullOrEmpty(ext) ? "other" : ext;
            })
            .Select(g => new FileTypeStat(g.Key, g.Count()))
            .OrderByDescending(x => x.Count)
            .Take(8)
            .ToList();

        _totalFileTypeCount = _fileTypeStats.Sum(x => x.Count);
        _lastUpdated = DateTime.Now;
    }

public void Dispose() => _timer?.Dispose();
}
