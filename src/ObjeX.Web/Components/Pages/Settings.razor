@page "/settings"
@using Microsoft.EntityFrameworkCore
@using ObjeX.Core.Models
@using ObjeX.Infrastructure.Data
@using ObjeX.Web.Components.Dialogs
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject ObjeXDbContext Db
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Settings — ObjeX</PageTitle>

<RadzenStack Gap="1.5rem">
    <RadzenText TextStyle="TextStyle.H4">Settings</RadzenText>

    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H6">Appearance</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween">
                <RadzenText>Dark mode</RadzenText>
                <RadzenSwitch @bind-Value="_isDark" Change="OnThemeChanged" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    @if (_isAdmin || _isManager)
    {
    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H6">Presigned URLs</RadzenText>
            <RadzenStack Gap="0.75rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText>Default expiry</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <input type="number" min="1" @oninput="OnDefaultValueInput" value="@_defaultValue"
                               class="rz-textbox no-spinner" style="width:72px;text-align:right" />
                        <RadzenDropDown @bind-Value="_defaultUnit" Data="_units"
                                        TextProperty="@nameof(TimeUnit.Label)" ValueProperty="@nameof(TimeUnit.Id)"
                                        Change="@(_ => ValidatePresignSettings())" Style="width:110px" />
                    </RadzenStack>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText>Maximum expiry</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <input type="number" min="1" @oninput="OnMaxValueInput" value="@_maxValue"
                               class="rz-textbox no-spinner" style="width:72px;text-align:right" />
                        <RadzenDropDown @bind-Value="_maxUnit" Data="_units"
                                        TextProperty="@nameof(TimeUnit.Label)" ValueProperty="@nameof(TimeUnit.Id)"
                                        Change="@(_ => ValidatePresignSettings())" Style="width:110px" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>
            @if (_presignError is not null)
            {
                <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-danger)">@_presignError</RadzenText>
            }
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
                <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Disabled="@(_presignError is not null)"
                              Click="SavePresignSettings" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>
    }

    @if (_isAdmin || _isManager)
    {
    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenText TextStyle="TextStyle.H6">Storage Quotas</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween">
                <RadzenText>Default quota per user</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <input type="number" min="0" @oninput="OnQuotaValueInput" value="@_quotaValue"
                           class="rz-textbox no-spinner" style="width:72px;text-align:right"
                           placeholder="∞" />
                    <RadzenDropDown @bind-Value="_quotaUnit" Data="_sizeUnits"
                                    TextProperty="@nameof(SizeUnit.Label)" ValueProperty="@nameof(SizeUnit.Id)"
                                    Style="width:80px" />
                </RadzenStack>
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">
                Applies to users with the User role only. Admins and Managers are unlimited by default. Per-user overrides can be set on the Users page.
            </RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
                <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                              Click="SaveQuotaSettings" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>
    }

    <RadzenCard>
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         JustifyContent="JustifyContent.SpaceBetween">
                <RadzenText TextStyle="TextStyle.H6">S3 Credentials</RadzenText>
                <RadzenButton Text="New Credential" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Size="ButtonSize.Small" Click="CreateCredential" />
            </RadzenStack>

            @if (_credentials.Count == 0)
            {
                <RadzenText Style="color:var(--rz-text-secondary-color)">No S3 credentials yet. Create one to access your buckets via the S3 API.</RadzenText>
            }
            else
            {
                <RadzenDataGrid Data="_credentials" TItem="S3Credential" AllowSorting="false"
                                Style="border:none">
                    <Columns>
                        <RadzenDataGridColumn TItem="S3Credential" Property="Name" Title="Name" />
                        <RadzenDataGridColumn TItem="S3Credential" Property="AccessKeyId" Title="Access Key ID">
                            <Template Context="cred">
                                <code style="font-size:0.85rem">@cred.AccessKeyId</code>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="S3Credential" Property="CreatedAt" Title="Created" Width="160px">
                            <Template Context="cred">
                                @cred.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="S3Credential" Property="LastUsedAt" Title="Last Used" Width="160px">
                            <Template Context="cred">
                                @(cred.LastUsedAt.HasValue ? cred.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Never")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="S3Credential" Title="" Width="60px" TextAlign="TextAlign.Right">
                            <Template Context="cred">
                                <RadzenButton Icon="delete" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                              Size="ButtonSize.Small" Click="@(() => DeleteCredential(cred))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenStack>
    </RadzenCard>
</RadzenStack>

<style>
    .no-spinner::-webkit-outer-spin-button,
    .no-spinner::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .no-spinner { -moz-appearance: textfield; }
</style>

@code {
    bool _isDark;
    bool _isAdmin;
    bool _isManager;
    string _userId = string.Empty;
    List<S3Credential> _credentials = [];

    // Quota config (admin)
    int _quotaValue;
    string _quotaUnit = "GB";

    record SizeUnit(string Id, string Label, long Multiplier);
    static readonly List<SizeUnit> _sizeUnits =
    [
        new("MB", "MB", 1024L * 1024),
        new("GB", "GB", 1024L * 1024 * 1024),
        new("TB", "TB", 1024L * 1024 * 1024 * 1024),
    ];

    // Presigned URL settings
    int _defaultValue = 1;
    string _defaultUnit = "hours";
    int _maxValue = 7;
    string _maxUnit = "days";
    string? _presignError;

    record TimeUnit(string Id, string Label, int Multiplier);
    static readonly List<TimeUnit> _units =
    [
        new("minutes", "Minutes", 60),
        new("hours",   "Hours",   3600),
        new("days",    "Days",    86400),
    ];

    int DefaultSeconds => _defaultValue * _units.First(u => u.Id == _defaultUnit).Multiplier;
    int MaxSeconds     => _maxValue     * _units.First(u => u.Id == _maxUnit).Multiplier;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        _isAdmin = auth.User.IsInRole("Admin");
        _isManager = auth.User.IsInRole("Manager");
        await LoadCredentials();
        if (_isAdmin || _isManager)
        {
            await LoadPresignSettings();
            await LoadQuotaSettings();
        }
    }

    async Task LoadPresignSettings()
    {
        var settings = await Db.SystemSettings.FindAsync(1);
        var defaultSec = settings?.PresignedUrlDefaultExpirySeconds ?? 3600;
        var maxSec     = settings?.PresignedUrlMaxExpirySeconds ?? 604800;

        (_defaultValue, _defaultUnit) = SecondsToValueUnit(defaultSec);
        (_maxValue,     _maxUnit)     = SecondsToValueUnit(maxSec);
    }

    static (int Value, string Unit) SecondsToValueUnit(int seconds)
    {
        if (seconds % 86400 == 0) return (seconds / 86400, "days");
        if (seconds % 3600  == 0) return (seconds / 3600,  "hours");
        return (seconds / 60, "minutes");
    }

    void OnDefaultValueInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1)
            _defaultValue = v;
        ValidatePresignSettings();
    }

    void OnMaxValueInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1)
            _maxValue = v;
        ValidatePresignSettings();
    }

    void ValidatePresignSettings()
    {
        _presignError = DefaultSeconds > MaxSeconds
            ? "Default expiry must not exceed the maximum expiry."
            : null;
    }

    async Task SavePresignSettings()
    {
        ValidatePresignSettings();
        if (_presignError is not null) return;

        var settings = await Db.SystemSettings.FindAsync(1);
        if (settings is null)
        {
            settings = new ObjeX.Core.Models.SystemSettings { Id = 1 };
            Db.SystemSettings.Add(settings);
        }
        settings.PresignedUrlDefaultExpirySeconds = DefaultSeconds;
        settings.PresignedUrlMaxExpirySeconds     = MaxSeconds;
        await Db.SaveChangesAsync();

        NotificationService.Notify(NotificationSeverity.Success, "Saved", "Presigned URL settings updated.");
    }

    async Task LoadQuotaSettings()
    {
        var settings = await Db.SystemSettings.FindAsync(1);
        var bytes = settings?.DefaultStorageQuotaBytes;
        if (bytes is null || bytes == 0)
        {
            _quotaValue = 0;
            _quotaUnit = "GB";
        }
        else
        {
            (_quotaValue, _quotaUnit) = BytesToValueUnit(bytes.Value);
        }
    }

    static (int Value, string Unit) BytesToValueUnit(long bytes)
    {
        if (bytes % (1024L * 1024 * 1024 * 1024) == 0) return ((int)(bytes / (1024L * 1024 * 1024 * 1024)), "TB");
        if (bytes % (1024L * 1024 * 1024) == 0) return ((int)(bytes / (1024L * 1024 * 1024)), "GB");
        return ((int)(bytes / (1024L * 1024)), "MB");
    }

    void OnQuotaValueInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v) && v >= 0)
            _quotaValue = v;
    }

    async Task SaveQuotaSettings()
    {
        var settings = await Db.SystemSettings.FindAsync(1);
        if (settings is null)
        {
            settings = new SystemSettings { Id = 1 };
            Db.SystemSettings.Add(settings);
        }

        settings.DefaultStorageQuotaBytes = _quotaValue == 0
            ? null
            : _quotaValue * _sizeUnits.First(u => u.Id == _quotaUnit).Multiplier;

        await Db.SaveChangesAsync();
        NotificationService.Notify(NotificationSeverity.Success, "Saved", "Storage quota updated.");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var cookie = await JS.InvokeAsync<string>("ObjeX.getCookie", "objex-theme");
        _isDark = cookie.Contains("dark");
        StateHasChanged();
    }

    async Task LoadCredentials()
    {
        _credentials = await Db.S3Credentials
            .Where(c => c.UserId == _userId)
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();
    }

    async Task CreateCredential()
    {
        var result = await DialogService.OpenAsync<CreateS3CredentialDialog>("New S3 Credential",
            options: new DialogOptions { CloseDialogOnOverlayClick = true, ShowClose = true });

        if (result is not CreateS3CredentialDialog.Result r) return;

        var (credential, secret) = S3Credential.Create(r.Name, _userId);
        Db.S3Credentials.Add(credential);
        await Db.SaveChangesAsync();
        await LoadCredentials();

        await DialogService.OpenAsync<ShowS3CredentialDialog>("Your New S3 Credential",
            new Dictionary<string, object?>
            {
                { "AccessKeyId", credential.AccessKeyId },
                { "SecretAccessKey", secret }
            },
            options: new DialogOptions { CloseDialogOnOverlayClick = false, ShowClose = false });
    }

    async Task DeleteCredential(S3Credential cred)
    {
        var confirmed = await DialogService.Confirm(
            $"Delete credential \"{cred.Name}\"? This cannot be undone.",
            "Delete Credential",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed != true) return;

        Db.S3Credentials.Remove(cred);
        await Db.SaveChangesAsync();
        await LoadCredentials();

        NotificationService.Notify(NotificationSeverity.Success, "Deleted", $"Credential \"{cred.Name}\" deleted.");
    }

    async Task OnThemeChanged(bool value)
    {
        var theme = value ? "material-dark" : "material";
        ThemeService.SetTheme(theme);
        await JS.InvokeVoidAsync("ObjeX.setCookie", "objex-theme", theme);
    }
}
